#!/bin/bash
# Dr. Math Commit-Message Hook
# Validates conventional commit format.
# Git invokes this hook with the path to the commit message file as $1.

COMMIT_MSG_FILE="$1"
FIRST_LINE=$(head -1 "$COMMIT_MSG_FILE")

# Allow merge commits and revert commits without conventional format
if echo "$FIRST_LINE" | grep -qE '^(Merge|Revert|fixup!|squash!)'; then
    exit 0
fi

# Allow empty messages (Git will reject them itself)
if [ -z "$FIRST_LINE" ]; then
    exit 0
fi

if ! echo "$FIRST_LINE" | grep -qE '^(feat|fix|docs|test|refactor|chore|research)(\(.+\))?: .+'; then
    echo ""
    echo "❌ FAILED: Commit message does not follow conventional commits."
    echo ""
    echo "   Format:  <type>[(scope)]: <description>"
    echo "   Types:   feat, fix, docs, test, refactor, chore, research"
    echo ""
    echo "   Examples:"
    echo "     feat(mobile): add quiz scoring animation"
    echo "     fix(pipeline): handle IXL timeout gracefully"
    echo "     docs(adr): document state management decision"
    echo ""
    echo "   Your message:"
    echo "     $FIRST_LINE"
    echo ""
    exit 1
fi

echo "✅ Conventional commit format verified."
